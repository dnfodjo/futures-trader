# ═══════════════════════════════════════════════════════════════════════
# MNQ Futures Trading System — Environment Variables
# ═══════════════════════════════════════════════════════════════════════
# Copy to .env and fill in your credentials:
#   cp .env.example .env
#
# NEVER commit .env — it contains secrets. .gitignore excludes it.
# ═══════════════════════════════════════════════════════════════════════

# ── QuantLynk (Order Execution) ──────────────────────────────────────
# Sign up at quantlynk.io → Link your Apex/Tradovate account
# Get webhook URL, user ID, and alert ID from your QuantLynk dashboard
QL_WEBHOOK_URL=your_quantlynk_webhook_url
QL_USER_ID=your_qv_user_id
QL_ALERT_ID=your_alert_id
QL_TIMEOUT_SEC=10.0
QL_MAX_RETRIES=2
QL_ENABLED=true

# ── Tradovate (OPTIONAL — only if using direct API instead of QuantLynk)
# TV_USERNAME=
# TV_PASSWORD=
# TV_CID=0
# TV_SEC=
# TV_DEVICE_ID=
# TV_USE_DEMO=true
# TV_ACCOUNT_NAME=

# ── Databento ─────────────────────────────────────────────────────────
# Sign up at databento.com → Subscribe to Standard ($179/mo) → Get API key
DB_API_KEY=your_databento_api_key

# ── Anthropic (Claude) ────────────────────────────────────────────────
# Get from console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-6-20260314
ANTHROPIC_MAX_RETRIES=3
ANTHROPIC_TIMEOUT_SEC=30
ANTHROPIC_DAILY_COST_CAP=10.0
ANTHROPIC_DAILY_COST_ALERT=5.0

# ── Telegram ──────────────────────────────────────────────────────────
# Message @BotFather → /newbot → save token
# Get chat_id: https://api.telegram.org/bot{TOKEN}/getUpdates
TG_BOT_TOKEN=your_telegram_bot_token
TG_CHAT_ID=your_telegram_chat_id
TG_THROTTLE_SEC=10.0
TG_HEARTBEAT_INTERVAL_MIN=30

# ── Trading Parameters ────────────────────────────────────────────────
# Contract (update quarterly: H=Mar, M=Jun, U=Sep, Z=Dec)
TRADE_SYMBOL=MNQM6
TRADE_POINT_VALUE=2.0
TRADE_TICK_SIZE=0.25
TRADE_COMMISSION_PER_RT=0.86

# Hard limits (guardrails — LLM CANNOT override these)
TRADE_MAX_CONTRACTS=6
TRADE_MAX_DAILY_LOSS=400.0
TRADE_MAX_WEEKLY_LOSS=800.0
TRADE_MAX_MONTHLY_LOSS=2000.0
TRADE_MAX_STOP_POINTS=25.0

# Trading hours (Eastern Time)
TRADE_TRADING_START=09:35
TRADE_TRADING_END=15:50
TRADE_HARD_FLATTEN_TIME=15:55
TRADE_PRE_MARKET_ANALYSIS_TIME=09:25

# News blackout windows
TRADE_NEWS_BLACKOUT_BEFORE_MIN=5
TRADE_NEWS_BLACKOUT_AFTER_MIN=10

# Flash crash detection
TRADE_FLASH_CRASH_THRESHOLD_POINTS=50.0
TRADE_FLASH_CRASH_WINDOW_SEC=60

# Connection safety
TRADE_CONNECTION_LOSS_MAX_SEC=30
TRADE_LLM_FAILURE_MAX_CONSECUTIVE=3

# Profit preservation tiers
TRADE_PROFIT_PRESERVATION_TIER1_PNL=200.0
TRADE_PROFIT_PRESERVATION_TIER1_MAX_SIZE=3
TRADE_PROFIT_PRESERVATION_TIER2_PNL=400.0
TRADE_PROFIT_PRESERVATION_TIER2_MAX_SIZE=2

# Circuit breakers
TRADE_CONSECUTIVE_RED_DAYS_HALF_SIZE=2
TRADE_CONSECUTIVE_RED_DAYS_SIM_ONLY=3

# State engine timing (seconds)
TRADE_STATE_UPDATE_INTERVAL_NO_POSITION_SEC=30.0
TRADE_STATE_UPDATE_INTERVAL_IN_POSITION_SEC=10.0
TRADE_STATE_UPDATE_INTERVAL_CRITICAL_SEC=5.0

# Trail manager
TRADE_TRAIL_MIN_MOVE_POINTS=3.0
TRADE_TRAIL_MIN_INTERVAL_SEC=10.0

# Stop hunt avoidance
TRADE_STOP_OFFSET_FROM_OBVIOUS_LEVELS=2.5

# Time-based exit reassessment
TRADE_TIME_EXIT_REASSESS_MIN=15
TRADE_TIME_EXIT_FORCE_MIN=25

# ── Apex Trader Funding Compliance ────────────────────────────────────
# Set APEX_ENABLED=true when running on an Apex evaluation or PA
TRADE_APEX_ENABLED=false
TRADE_APEX_ACCOUNT_TYPE=50k
TRADE_APEX_FLATTEN_DEADLINE=16:54
TRADE_APEX_DRAWDOWN_LOCKOUT_PCT=0.75

# ── VPS Deployment ────────────────────────────────────────────────────
# Used by scripts/deploy.sh and GitHub Actions
# VPS_HOST, VPS_USER, VPS_SSH_KEY should be set as GitHub repo secrets,
# NOT in this file. Listed here for documentation only.
# VPS_HOST=your.vps.ip.address
# VPS_USER=trader
# VPS_SSH_KEY=(base64-encoded private key — store in GitHub Secrets only)
VPS_DEPLOY_PATH=/opt/futures-trader

# ── App-Level ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DATA_DIR=./data
JOURNAL_PATH=./data/journal.db
LOCK_FILE=/tmp/futures-trader.lock
TIMEZONE=US/Eastern
